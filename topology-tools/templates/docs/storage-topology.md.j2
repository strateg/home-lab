    {% set desc_lower = (pool.description | default('') | lower) %}
    {% set type_lower = (pool.type | default('') | lower) %}
    {% if media_lower == 'nvme' %}
    class {{ pool.id | mermaid_id }} nvme
    {% elif media_lower == 'ssd' %}
    class {{ pool.id | mermaid_id }} ssd
    {% elif media_lower == 'hdd' %}
    class {{ pool.id | mermaid_id }} hdd
    {% elif 'nvme' in desc_lower %}
    class {{ pool.id | mermaid_id }} nvme
    {% elif 'ssd' in desc_lower or 'lvm' in type_lower %}
    class {{ pool.id | mermaid_id }} ssd
    {% elif 'hdd' in desc_lower %}
    class {{ pool.id | mermaid_id }} hdd
    {% else %}
    class {{ pool.id | mermaid_id }} pool
    {% endif %}
    {% endfor %}
    {% for asset in data_assets %}
    class {{ asset.id | mermaid_id }} data
    {% endfor %}

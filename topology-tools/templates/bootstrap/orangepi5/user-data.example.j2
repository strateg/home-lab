#cloud-config
hostname: {{ hostname }}
fqdn: {{ fqdn }}
manage_etc_hosts: true

users:
  - name: {{ cloud_init_user }}
    gecos: {{ device_name }}
    groups:
      - sudo
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
{% if has_topology_keys %}
    ssh_authorized_keys:
{% for key in ssh_authorized_keys %}
      - {{ key }}
{% endfor %}
{% else %}
    ssh_authorized_keys:
      - {{ ssh_key_placeholder }}
{% endif %}

ssh_pwauth: false
disable_root: true
package_update: true

write_files:
  - path: /etc/motd
    permissions: "0644"
    content: |
      {{ device_name }} bootstrap
      topology host: {{ hostname }}
      lan_ip: {{ lan_ip or "dhcp" }}
      management_ip: {{ management_ip or "not-modeled" }}

runcmd:
  - [ sh, -c, "echo cloud-init bootstrap complete for {{ hostname }}" ]

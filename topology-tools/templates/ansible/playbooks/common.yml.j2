---
# Common Host Configuration Playbook
# Generated by AnsibleRoleGenerator (ADR 0104) - DO NOT EDIT MANUALLY
#
# Usage:
#   ansible-playbook -i inventory/hosts.yml playbooks/common.yml
#
# Configures base settings on Linux hosts with cap.role.linux_host

- name: Configure Linux Hosts
  hosts: linux_hosts
  gather_facts: true
  become: true

  pre_tasks:
    - name: Verify connectivity
      ansible.builtin.ping:

    - name: Display target host info
      ansible.builtin.debug:
        msg: |
          Configuring Linux Host:
            Host: {{ '{{' }} inventory_hostname {{ '}}' }}
            IP: {{ '{{' }} ansible_host | default(ansible_default_ipv4.address) {{ '}}' }}

  roles:
    - role: common

  post_tasks:
    - name: Verify hostname configuration
      ansible.builtin.command: hostname
      register: hostname_result
      changed_when: false

    - name: Verify NTP synchronization
      ansible.builtin.command: timedatectl status
      register: timedatectl_result
      changed_when: false
      failed_when: false

    - name: Display final status
      ansible.builtin.debug:
        msg: |
          Common Configuration Complete:

          Hostname: {{ '{{' }} hostname_result.stdout {{ '}}' }}

          Time Status:
          {{ '{{' }} timedatectl_result.stdout_lines[:5] | join('\n') {{ '}}' }}

  tags:
    - common
    - base

---
# Node Exporter Installation Playbook
# Generated by AnsibleRoleGenerator (ADR 0104) - DO NOT EDIT MANUALLY
#
# Usage:
#   ansible-playbook -i inventory/hosts.yml playbooks/node_exporter.yml
#
# Installs Prometheus node_exporter on hosts with cap.role.monitoring_target

- name: Install Node Exporter
  hosts: monitoring_targets
  gather_facts: true
  become: true

  pre_tasks:
    - name: Verify connectivity
      ansible.builtin.ping:

    - name: Display target host info
      ansible.builtin.debug:
        msg: |
          Installing Node Exporter:
            Host: {{ '{{' }} inventory_hostname {{ '}}' }}
            IP: {{ '{{' }} ansible_host | default(ansible_default_ipv4.address) {{ '}}' }}

  roles:
    - role: node_exporter

  post_tasks:
    - name: Verify node_exporter is running
      ansible.builtin.systemd:
        name: node_exporter
        state: started
      register: node_exporter_service
      check_mode: true

    - name: Check metrics endpoint
      ansible.builtin.uri:
        url: "http://{{ '{{' }} ansible_host | default('localhost') {{ '}}' }}:{{ '{{' }} node_exporter.port | default(9100) {{ '}}' }}/metrics"
        return_content: false
        status_code: 200
      register: metrics_check
      failed_when: false

    - name: Display final status
      ansible.builtin.debug:
        msg: |
          Node Exporter Installation Complete:

          Service Status: {{ '{{' }} node_exporter_service.status.ActiveState | default('unknown') {{ '}}' }}
          Metrics Endpoint: {{ '{{' }} 'OK' if metrics_check.status == 200 else 'FAILED' {{ '}}' }}
          Port: {{ '{{' }} node_exporter.port | default(9100) {{ '}}' }}

  tags:
    - monitoring
    - node_exporter
    - prometheus

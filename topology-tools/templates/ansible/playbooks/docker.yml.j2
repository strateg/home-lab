---
# Docker Host Configuration Playbook
# Generated by AnsibleRoleGenerator (ADR 0104) - DO NOT EDIT MANUALLY
#
# Usage:
#   ansible-playbook -i inventory/hosts.yml playbooks/docker.yml
#
# Configures Docker runtime on Linux hosts with cap.compute.runtime.container_host

- name: Configure Docker Hosts
  hosts: docker_hosts
  gather_facts: true
  become: true

  pre_tasks:
    - name: Verify connectivity
      ansible.builtin.ping:

    - name: Display target host info
      ansible.builtin.debug:
        msg: |
          Configuring Docker Host:
            Host: {{ '{{' }} inventory_hostname {{ '}}' }}
            IP: {{ '{{' }} ansible_host | default(ansible_default_ipv4.address) {{ '}}' }}

  roles:
    - role: docker_host

  post_tasks:
    - name: Verify Docker is running
      ansible.builtin.command: docker info
      register: docker_info
      changed_when: false

    - name: Verify Docker Compose is available
      ansible.builtin.command: docker compose version
      register: compose_version
      changed_when: false

    - name: Display final status
      ansible.builtin.debug:
        msg: |
          Docker Host Configuration Complete:

          Docker Info:
          {{ '{{' }} docker_info.stdout_lines[:5] | join('\n') {{ '}}' }}

          Docker Compose:
          {{ '{{' }} compose_version.stdout {{ '}}' }}

  tags:
    - docker
    - containers

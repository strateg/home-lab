---
# VPN Gateway Configuration Playbook
# Generated by AnsibleRoleGenerator (ADR 0104) - DO NOT EDIT MANUALLY
# Configures {{ instance_ref }} as WireGuard gateway for VPN VLAN geo-bypass
#
# Usage:
#   ansible-playbook -i inventory/production/hosts.yml playbooks/vpn-gateway.yml
#
# Prerequisites:
#   - SOPS + age configured for secret decryption
#   - SSH access to target host

- name: Configure VPN Gateway
  hosts: {{ instance_ref }}
  gather_facts: true
  become: true

  vars:
    secrets_base_path: "{{ '{{' }} playbook_dir {{ '}}' }}/../../../../projects/home-lab/secrets"

  pre_tasks:
    - name: Load WireGuard secrets from SOPS
      ansible.builtin.set_fact:
        wireguard_secrets: "{{ '{{' }} lookup('community.sops.sops', secrets_base_path + '/' + secrets.tunnel) | from_yaml {{ '}}' }}"
      delegate_to: localhost
      become: false

    - name: Verify connectivity
      ansible.builtin.ping:

    - name: Display target host info
      ansible.builtin.debug:
        msg: |
          Configuring VPN Gateway:
            Host: {{ '{{' }} inventory_hostname {{ '}}' }}
            IP: {{ '{{' }} ansible_host {{ '}}' }}
            Interface: {{ '{{' }} primary_interface {{ '}}' }}
            Tunnel: {{ '{{' }} wireguard.interface {{ '}}' }}

  roles:
    - role: wireguard_gateway

  post_tasks:
    - name: Verify WireGuard is running
      ansible.builtin.command: wg show {{ '{{' }} wireguard.interface {{ '}}' }}
      register: wg_final_status
      changed_when: false

    - name: Verify IP forwarding is enabled
      ansible.builtin.command: sysctl net.ipv4.ip_forward
      register: ip_forward_status
      changed_when: false

    - name: Verify iptables NAT rules
      ansible.builtin.shell: |
        iptables -t nat -L POSTROUTING -n -v | grep -E "MASQUERADE|{{ routed_networks[0].network.split('/')[0] if routed_networks else '192.168' }}"
      register: nat_rules
      changed_when: false

    - name: Display final status
      ansible.builtin.debug:
        msg: |
          VPN Gateway Configuration Complete:

          WireGuard Status:
          {{ '{{' }} wg_final_status.stdout {{ '}}' }}

          IP Forwarding: {{ '{{' }} ip_forward_status.stdout {{ '}}' }}

          NAT Rules:
          {{ '{{' }} nat_rules.stdout {{ '}}' }}

  tags:
    - vpn
    - wireguard
    - gateway

---
# Host variables for {{ instance_id }}
# Generated by AnsibleRoleGenerator (ADR 0104) - DO NOT EDIT MANUALLY

# Instance identification
instance_id: {{ instance_id }}
instance_group: {{ group }}
instance_role: docker_host

# Docker configuration
docker:
  version: "{{ docker_version | default('latest') }}"
  storage_driver: "{{ docker_storage_driver | default('overlay2') }}"
  log_driver: "{{ docker_log_driver | default('json-file') }}"
  log_opts:
    max_size: "{{ docker_log_max_size | default('10m') }}"
    max_file: "{{ docker_log_max_file | default('3') }}"

# Container runtime settings
container_runtime:
  data_root: "{{ container_data_root | default('/var/lib/docker') }}"
  enable_ipv6: {{ container_enable_ipv6 | default('false') | lower }}

# Network configuration for containers
docker_networks:
{% for network in docker_networks | default([]) %}
  - name: {{ network.name }}
    driver: {{ network.driver | default('bridge') }}
{% if network.subnet is defined %}
    subnet: {{ network.subnet }}
{% endif %}
{% endfor %}

# Packages to install
packages:
  - docker-ce
  - docker-ce-cli
  - containerd.io
  - docker-compose-plugin

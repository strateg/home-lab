---
# Host variables for {{ instance_id }}
# Generated by AnsibleRoleGenerator (ADR 0104) - DO NOT EDIT MANUALLY

# Instance identification
instance_id: {{ instance_id }}
instance_group: {{ group }}
instance_role: common

# System configuration
hostname: {{ instance_id }}
timezone: "{{ timezone | default('UTC') }}"
locale: "{{ locale | default('en_US.UTF-8') }}"

# SSH configuration
ssh:
  port: {{ ssh_port | default(22) }}
  permit_root_login: {{ ssh_permit_root | default('no') }}
  password_authentication: {{ ssh_password_auth | default('no') }}

# NTP configuration
ntp:
  enabled: true
  servers:
{% for server in ntp_servers | default(['0.pool.ntp.org', '1.pool.ntp.org']) %}
    - {{ server }}
{% endfor %}

# Basic packages
packages:
  - curl
  - wget
  - vim
  - htop
  - tmux
  - git

# Firewall base rules (ufw)
firewall:
  enabled: {{ firewall_enabled | default('true') | lower }}
  default_incoming: {{ firewall_default_incoming | default('deny') }}
  default_outgoing: {{ firewall_default_outgoing | default('allow') }}
  rules:
    - rule: allow
      port: {{ ssh_port | default(22) }}
      proto: tcp
      comment: SSH

---
# Host variables for {{ instance_ref }}
# Generated by AnsibleRoleGenerator (ADR 0104) - DO NOT EDIT MANUALLY
# Source: topology/instances/vm/cloud/{{ instance_ref }}.yaml

# Instance identification
instance_ref: {{ instance_ref }}
instance_group: {{ instance_group }}
instance_role: {{ instance_role }}

# Network configuration
primary_interface: {{ primary_interface }}
tunnel_interface: {{ tunnel_interface }}

# WireGuard configuration
wireguard:
  interface: {{ wireguard.interface }}
  listen_port: {{ wireguard.listen_port }}
  tunnel_ip: {{ wireguard.tunnel_ip }}
  role: {{ wireguard.role }}
  private_key_file: {{ wireguard.private_key_file }}
  config_file: {{ wireguard.config_file }}

# Secrets references (decrypted at runtime via SOPS)
# Path relative to project root: projects/home-lab/secrets/
secrets:
  tunnel: {{ secrets.tunnel }}
  instance: {{ secrets.instance }}

# Peer configuration (MikroTik Chateau)
# Public key loaded from secrets.tunnel.mikrotik.public_key
wireguard_peers:
{% for peer in wireguard_peers %}
  - name: {{ peer.name }}
    public_key: "{{ peer.public_key }}"
    allowed_ips:
{% for ip in peer.allowed_ips %}
      - {{ ip }}
{% endfor %}
{% if peer.persistent_keepalive is defined %}
    persistent_keepalive: {{ peer.persistent_keepalive }}
{% endif %}
{% endfor %}

# IP forwarding and NAT for VPN gateway
ip_forwarding: {{ ip_forwarding | lower }}

# Routed networks (traffic from these networks gets NAT'd)
routed_networks:
{% for net in routed_networks %}
  - network: {{ net.network }}
    comment: "{{ net.comment }}"
    nat: {{ net.nat }}
{% endfor %}

# iptables rules for forwarding
iptables_forward_rules:
{% for rule in iptables_forward_rules %}
  - "{{ rule }}"
{% endfor %}

iptables_nat_rules:
{% for rule in iptables_nat_rules %}
  - "{{ rule }}"
{% endfor %}

# Packages to install
packages:
  - wireguard
  - wireguard-tools
  - iptables-persistent
  - conntrack

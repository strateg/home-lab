---
# Host variables for {{ instance_id }}
# Generated by AnsibleRoleGenerator (ADR 0104) - DO NOT EDIT MANUALLY

# Instance identification
instance_id: {{ instance_id }}
instance_group: {{ group }}
instance_role: node_exporter

# Node exporter configuration
node_exporter:
  version: "{{ node_exporter_version | default('latest') }}"
  port: {{ node_exporter_port | default(9100) }}
  listen_address: "{{ node_exporter_listen | default('0.0.0.0') }}"

# Collectors to enable
node_exporter_collectors:
{% for collector in node_exporter_collectors | default(['cpu', 'diskstats', 'filesystem', 'loadavg', 'meminfo', 'netdev', 'stat', 'time', 'uname']) %}
  - {{ collector }}
{% endfor %}

# Collectors to disable
node_exporter_disabled_collectors:
{% for collector in node_exporter_disabled_collectors | default([]) %}
  - {{ collector }}
{% endfor %}

# Firewall rules for node_exporter
firewall_rules:
  - rule: allow
    port: {{ node_exporter_port | default(9100) }}
    proto: tcp
    from: "{{ prometheus_server_ip | default('any') }}"
    comment: "Node Exporter metrics"

# Systemd service settings
node_exporter_service:
  enabled: true
  state: started
  restart_policy: always

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://home-lab.local/schemas/v5/plugin-manifest.schema.json",
  "title": "Plugin Manifest Schema",
  "description": "Schema for v5 topology plugin manifests (ADR 0063, ADR 0080 lifecycle model)",
  "type": "object",
  "required": ["schema_version", "plugins"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Manifest schema version"
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plugin"
      },
      "description": "List of plugins declared by this manifest"
    }
  },
  "$defs": {
    "plugin": {
      "type": "object",
      "$comment": "Cross-entry dependency guards (depends_on may not target later phase/stage) are enforced by registry runtime validation, not pure JSON Schema.",
      "required": ["id", "kind", "entry", "api_version", "stages", "order"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_.]*$",
          "description": "Globally unique plugin identifier (format: {module_id}.{plugin_kind}.{specific_name})"
        },
        "kind": {
          "type": "string",
          "enum": ["discoverer", "compiler", "validator_yaml", "validator_json", "generator", "assembler", "builder"],
          "description": "Plugin kind determining execution context"
        },
        "entry": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_/.-]+\\.py:[A-Z][a-zA-Z0-9_]*$",
          "description": "Entry point as 'path/to/module.py:ClassName'"
        },
        "api_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.x$",
          "description": "Plugin API version compatibility (format: major.x, e.g., '1.x')"
        },
        "stages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["discover", "compile", "validate", "generate", "assemble", "build"]
          },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Pipeline stages where this plugin executes"
        },
        "phase": {
          "type": "string",
          "enum": ["init", "pre", "run", "post", "verify", "finalize"],
          "description": "Optional lifecycle phase within stage (ADR 0080). Defaults to run when omitted."
        },
        "order": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9999,
          "description": "Execution order within stage/phase (higher number = later execution)"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Plugin IDs that must execute before this plugin"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Capabilities provided by this plugin"
        },
        "requires_capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Capabilities required from context for this plugin to run"
        },
        "config": {
          "type": "object",
          "description": "Static configuration defaults (validated against config_schema)",
          "additionalProperties": true
        },
        "config_schema": {
          "type": "object",
          "description": "JSON Schema for validating plugin configuration"
        },
        "when": {
          "type": "object",
          "description": "Optional execution gating predicates.",
          "properties": {
            "profiles": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["production", "modeled", "test-real"]
              }
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "pipeline_modes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "changed_input_scopes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "produces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/produces"
          }
        },
        "consumes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/consumes"
          }
        },
        "compiled_json_owner": {
          "type": "boolean",
          "default": false,
          "description": "Marks the sole plugin allowed to publish compiled_json for a given stage+phase."
        },
        "model_versions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional model version compatibility declarations for this plugin."
        },
        "timeout": {
          "type": "number",
          "minimum": 1,
          "maximum": 300,
          "default": 30,
          "description": "Maximum execution time in seconds (default: 30s)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what this plugin does"
        },
        "migration_mode": {
          "type": "string",
          "enum": ["legacy", "migrating", "migrated", "rollback"],
          "description": "Optional generator migration lifecycle mode for ADR0093 cutover."
        },
        "subinterpreter_compatible": {
          "type": "boolean",
          "default": false,
          "description": "DEPRECATED: Use execution_mode instead. Whether this plugin supports execution in Python 3.14+ subinterpreters (ADR 0097). Default false for backward compatibility.",
          "deprecated": true
        },
        "execution_mode": {
          "type": "string",
          "enum": ["subinterpreter", "main_interpreter", "thread_legacy"],
          "default": "main_interpreter",
          "description": "Plugin execution mode (ADR 0097 PR2). 'subinterpreter': isolated execution in Python 3.14+ subinterpreter. 'main_interpreter': envelope-based execution in main interpreter. 'thread_legacy': legacy execute_plugin() path for compatibility."
        }
      },
      "additionalProperties": false
    },
    "produces": {
      "type": "object",
      "required": ["key"],
      "properties": {
        "key": {
          "type": "string"
        },
        "schema_ref": {
          "type": "string"
        },
        "scope": {
          "type": "string",
          "enum": ["stage_local", "pipeline_shared"]
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "consumes": {
      "type": "object",
      "required": ["from_plugin", "key"],
      "properties": {
        "from_plugin": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "schema_ref": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

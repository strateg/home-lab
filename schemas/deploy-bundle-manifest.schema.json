{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://home-lab.local/schemas/deploy-bundle-manifest.schema.json",
  "title": "Deploy Bundle Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "created_at",
    "source",
    "nodes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "topology_hash",
        "secrets_hash"
      ],
      "properties": {
        "project": {
          "type": "string",
          "minLength": 1
        },
        "topology_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "secrets_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "mechanism",
          "artifacts"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "mechanism": {
            "type": "string",
            "minLength": 1
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "path",
                "checksum"
              ],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "checksum": {
                  "type": "string",
                  "pattern": "^sha256:[0-9a-f]{64}$"
                }
              }
            }
          }
        }
      }
    }
  }
}

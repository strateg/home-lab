{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://home-lab.local/schemas/artifact-generation-report.schema.json",
  "title": "Artifact Generation Report",
  "description": "Generator execution report contract for migrated artifact families (ADR 0093)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plugin_id",
    "artifact_family",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+$"
    },
    "plugin_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_.]*$"
    },
    "artifact_family": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "generated": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "obsolete": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/obsolete_entry"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planned_count",
        "generated_count",
        "skipped_count",
        "obsolete_count"
      ],
      "properties": {
        "planned_count": {
          "type": "integer",
          "minimum": 0
        },
        "generated_count": {
          "type": "integer",
          "minimum": 0
        },
        "skipped_count": {
          "type": "integer",
          "minimum": 0
        },
        "obsolete_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "obsolete_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "action",
        "reason"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "enum": [
            "retain",
            "delete",
            "warn"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

  Ключевые принципы

  1. Зависимости только вниз — lxc_ref в L5 ссылается на L4, network_ref в L4 на L2
  2. Генераторы обрабатывают L0→L7 — сначала разрешаются нижние слои
  3. Изоляция изменений — изменение L5 не требует изменений в L1-L4

  Новая структура файлов

  topology/
  ├── L0-meta.yaml          # version, defaults, policies
  ├── L1-foundation.yaml    # devices, interfaces, UPS
  ├── L2-network.yaml       # networks, bridges, trust_zones, firewall
  ├── L3-data.yaml          # storage, backup_policies
  ├── L4-platform.yaml      # vms, lxc, templates
  ├── L5-application.yaml   # services, certificates
  ├── L6-observability.yaml # healthchecks, alerts, dashboards
  └── L7-operations.yaml    # workflows, runbooks, documentation

  Пример референсов по слоям

  # L4-platform.yaml
  lxc:
    - id: lxc-postgresql
      device_ref: dev-gamayun      # → L1 (вниз)
      trust_zone_ref: zone-servers # → L2 (вниз)
      storage_ref: storage-lvm     # → L3 (вниз)
      network_ref: net-servers     # → L2 (вниз)

  # L5-application.yaml
  services:
    - id: svc-nextcloud
      lxc_ref: lxc-postgresql      # → L4 (вниз)
      network_ref: net-servers     # → L2 (вниз)
      dependencies:
        - service_ref: svc-redis   # → L5 (тот же слой, допустимо)


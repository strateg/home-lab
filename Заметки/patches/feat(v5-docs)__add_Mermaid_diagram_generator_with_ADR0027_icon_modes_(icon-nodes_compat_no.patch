+# Physical Topology
+
+Generated by `base.generator.diagrams`.
+{% if use_mermaid_icons %}
+
+> {{ mermaid_icon_runtime_hint }}
+{% endif %}
+
+## Device Topology
+
+```mermaid
+graph TB
+{% for device in devices %}
+{% if use_mermaid_icons %}
+    {{ device.safe_id }}@{ icon: "{{ device.icon }}", form: "rounded", label: "{{ device.instance_id }}", pos: "b", h: 44 }
+{% else %}
+{% if icon_mode == 'compat' %}
+    {{ device.safe_id }}["{{ device.instance_id }}<br/>{{ device.icon }}"]
+{% else %}
+    {{ device.safe_id }}["{{ device.instance_id }}<br/>{{ device.class_ref }}"]
+{% endif %}
+{% endif %}
+{% endfor %}
+{% for link in data_links %}
+{% if link.endpoint_a and link.endpoint_b %}
+{% set src = link.endpoint_a.device_ref | default(link.endpoint_a.get('external_ref', 'unknown')) | replace('.', '_') | replace('-', '_') %}
+{% set dst = link.endpoint_b.device_ref | default(link.endpoint_b.get('external_ref', 'unknown')) | replace('.', '_') | replace('-', '_') %}
+{% if link.medium in ['wifi', 'lte', 'wwan'] %}
+    {{ src }} -.->|{{ link.medium | upper }}{% if link.speed_mbps %} {{ link.speed_mbps }}Mbps{% endif %}| {{ dst }}
+{% else %}
+    {{ src }} -->|{{ link.medium | upper }}{% if link.speed_mbps %} {{ link.speed_mbps }}Mbps{% endif %}| {{ dst }}
+{% endif %}
+{% endif %}
+{% endfor %}
+
+    classDef router fill:#4dabf7,stroke:#1864ab,color:#fff
+    classDef hypervisor fill:#51cf66,stroke:#2b8a3e,color:#000
+    classDef edge fill:#ffd43b,stroke:#fab005,color:#000
+    classDef cloud fill:#ffc078,stroke:#e8590c,color:#000
+    classDef default fill:#e9ecef,stroke:#868e96,color:#000
+
+{% for device in devices %}
+{% if 'router' in device.class_ref %}
+    class {{ device.safe_id }} router
+{% elif 'hypervisor' in device.class_ref %}
+    class {{ device.safe_id }} hypervisor
+{% elif 'edge_node' in device.class_ref %}
+    class {{ device.safe_id }} edge
+{% elif 'cloud_vm' in device.class_ref %}
+    class {{ device.safe_id }} cloud
+{% endif %}
+{% endfor %}
+```
+
+---
+
+## Device Inventory
+
+| Instance | Class | Object | Layer | Status |
+| --- | --- | --- | --- | --- |
+{% for device in devices -%}
+| **{{ device.instance_id }}** | {{ device.class_ref }} | {{ device.object_ref }} | {{ device.layer }} | {{ device.status }} |
+{% endfor %}
+
+---
+
+## Data Link Inventory
+
+| Link | Medium | Endpoint A | Endpoint B | Speed | Status |
+| --- | --- | --- | --- | --- | --- |
+{% for link in data_links -%}
+| {{ link.instance_id }} | {{ link.medium | upper }} | {{ link.endpoint_a.device_ref | default(link.endpoint_a.get('external_ref', '-')) }} | {{ link.endpoint_b.device_ref | default(link.endpoint_b.get('external_ref', '-')) }} | {{ link.speed_mbps | default('-') }}{% if link.speed_mbps %} Mbps{% endif %} | {{ link.status }} |
+{% endfor %}
+
+---
+
+*DO NOT EDIT MANUALLY - regenerate with `task build:v5-docs`*

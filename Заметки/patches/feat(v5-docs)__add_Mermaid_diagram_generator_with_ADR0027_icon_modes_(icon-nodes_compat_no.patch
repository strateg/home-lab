+{% if use_mermaid_icons %}
+        {{ vlan.safe_id }}@{ icon: "{{ vlan.icon }}", form: "rounded", label: "{{ vlan.label }}{% if vlan.vlan_id %} (VLAN {{ vlan.vlan_id }}){% endif %}{% if vlan.cidr %} {{ vlan.cidr }}{% endif %}", pos: "b", h: 44 }

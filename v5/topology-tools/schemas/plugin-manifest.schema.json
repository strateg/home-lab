{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://home-lab.local/schemas/v5/plugin-manifest.schema.json",
  "title": "Plugin Manifest Schema",
  "description": "Schema for v5 topology plugin manifests (ADR 0063)",
  "type": "object",
  "required": ["schema_version", "plugins"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Manifest schema version"
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plugin"
      },
      "description": "List of plugins declared by this manifest"
    }
  },
  "$defs": {
    "plugin": {
      "type": "object",
      "required": ["id", "kind", "entry", "api_version", "stages", "order"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_.]*$",
          "description": "Globally unique plugin identifier (e.g., 'base.validator.references')"
        },
        "kind": {
          "type": "string",
          "enum": ["compiler", "validator_yaml", "validator_json", "generator"],
          "description": "Plugin kind determining execution context"
        },
        "entry": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_/.-]+\\.py:[A-Z][a-zA-Z0-9_]*$",
          "description": "Entry point as 'path/to/module.py:ClassName'"
        },
        "api_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.x$",
          "description": "Plugin API version compatibility (e.g., '1.x')"
        },
        "stages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["load", "normalize", "resolve", "validate", "emit"]
          },
          "minItems": 1,
          "description": "Pipeline stages where this plugin executes"
        },
        "order": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9999,
          "description": "Execution order within stage (lower runs first)"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Plugin IDs this plugin depends on"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Capabilities provided by this plugin"
        },
        "config_schema": {
          "type": "object",
          "description": "Optional JSON Schema for plugin configuration"
        },
        "profile_restrictions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["production", "modeled", "test-real"]
          },
          "description": "Profiles where this plugin is allowed to run (all if not specified)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of what this plugin does"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

# Local Secrets Template
# Copy to all-secrets.yml and fill in actual values
# all-secrets.yml is gitignored - NEVER commit actual secrets
#
# Part of ADR 0051: Ansible Runtime, Inventory, and Secret Boundaries

# ============================================================
# Admin Users
# ============================================================

admin_users:
  - name: admin
    comment: "Home Lab Administrator"
    shell: /bin/bash
    groups:
      - sudo
      - adm
    ssh_keys:
      - "ssh-rsa AAAA... your-public-key-here"
      # Add more keys as needed

# ============================================================
# Service Credentials (if needed)
# ============================================================

# Example: Database credentials
# db_admin_password: "your-secure-password-here"

# Example: API tokens
# grafana_admin_password: "your-secure-password-here"
# prometheus_basic_auth_password: "your-secure-password-here"

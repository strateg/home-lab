version: "3.9"

services:
  prometheus:
    image: {{ monitoring_prometheus_image }}
    container_name: prometheus
    restart: unless-stopped
    ports:
      - "{{ monitoring_prometheus_port }}:9090"
    volumes:
      - ./config/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./data/prometheus:/prometheus
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.path=/prometheus

  loki:
    image: {{ monitoring_loki_image }}
    container_name: loki
    restart: unless-stopped
    ports:
      - "{{ monitoring_loki_port }}:3100"
    volumes:
      - ./config/loki/loki-config.yml:/etc/loki/local-config.yaml:ro
      - ./data/loki:/loki
    command:
      - -config.file=/etc/loki/local-config.yaml

  alertmanager:
    image: {{ monitoring_alertmanager_image }}
    container_name: alertmanager
    restart: unless-stopped
    ports:
      - "{{ monitoring_alertmanager_port }}:9093"
    volumes:
      - ./config/alertmanager/alertmanager.yml:/etc/alertmanager/alertmanager.yml:ro
    command:
      - --config.file=/etc/alertmanager/alertmanager.yml

  grafana:
    image: {{ monitoring_grafana_image }}
    container_name: grafana
    restart: unless-stopped
    ports:
      - "{{ monitoring_grafana_port }}:3000"
    environment:
      GF_SECURITY_ADMIN_USER: "{{ monitoring_grafana_admin_user }}"
      GF_SECURITY_ADMIN_PASSWORD: "{{ monitoring_grafana_admin_password }}"
    volumes:
      - ./data/grafana:/var/lib/grafana
    depends_on:
      - prometheus
      - loki

# MikroTik Bridge Host entries for MAC-based VLAN assignment
# Generated from topology device instances with vlan_ref + secrets_ref
#
# Devices with specified MAC addresses will be automatically assigned to
# the target VLAN regardless of port PVID. All other devices use port default.
#
# MAC addresses are passed via Terraform variable (from secrets).

{% if mac_vlan_assignments %}
# MAC-based VLAN assignments from device instances:
{% for entry in mac_vlan_assignments %}
# - {{ entry.device_name }}: {{ entry.secrets_path }} -> VLAN {{ entry.vlan_id }}
{% endfor %}

resource "routeros_interface_bridge_host" "mac_vlan" {
  for_each = { for idx, entry in var.mac_vlan_assignments : entry.device_id => entry }

  bridge      = "bridge"
  mac_address = each.value.mac_address
  vid         = each.value.vlan_id
  comment     = each.value.comment

  lifecycle {
    create_before_destroy = false
  }
}
{% else %}
# No MAC-based VLAN assignments configured
# To enable: add vlan_ref and secrets_ref to device instances in data-assets/
{% endif %}

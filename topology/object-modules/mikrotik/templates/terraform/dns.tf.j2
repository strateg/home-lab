# MikroTik DNS configuration generated from topology

resource "routeros_ip_dns" "settings" {
  allow_remote_requests = true
{% if runtime_baseline.dns_servers %}
  servers               = [{% for dns in runtime_baseline.dns_servers %}"{{ dns }}"{% if not loop.last %}, {% endif %}{% endfor %}]
{% else %}
  servers               = ["1.1.1.1", "8.8.8.8"]
{% endif %}
  cache_max_ttl         = "1w"
  cache_size            = 2048
}

{% if vlans %}
# Static DNS entries for VLAN gateways
{% for vlan in vlans %}
{% if vlan.gateway %}
resource "routeros_ip_dns_record" "{{ vlan.name }}_gw" {
  name    = "gw-{{ vlan.name }}.lan"
  address = "{{ vlan.gateway }}"
  type    = "A"
  comment = "{{ vlan.instance_id }} gateway - managed by topology"
}

{% endif %}
{% endfor %}
{% endif %}

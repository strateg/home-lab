# MikroTik WireGuard VPN configuration
# Generated from topology - DO NOT EDIT MANUALLY

locals {
  wireguard_interface_name = "wg0"
}

{% if has_wireguard %}
# WireGuard Interface
resource "routeros_interface_wireguard" "wg0" {
  name        = local.wireguard_interface_name
  listen_port = {{ wireguard_listen_port | default(51820) }}
  private_key = var.wireguard_private_key
  mtu         = {{ wireguard_mtu | default(1420) }}
  comment     = "WireGuard tunnel - managed by topology"
}

# WireGuard Peers
{% for peer in wireguard_peers %}
resource "routeros_interface_wireguard_peer" "{{ peer.name | replace('-', '_') }}" {
  interface            = routeros_interface_wireguard.wg0.name
  public_key           = var.wireguard_peers[{{ loop.index0 }}].public_key
  preshared_key        = var.wireguard_peers[{{ loop.index0 }}].preshared_key
  endpoint_address     = var.wireguard_peers[{{ loop.index0 }}].endpoint_address
  endpoint_port        = var.wireguard_peers[{{ loop.index0 }}].endpoint_port
  allowed_address      = var.wireguard_peers[{{ loop.index0 }}].allowed_ips
  persistent_keepalive = var.wireguard_peers[{{ loop.index0 }}].persistent_keepalive
  comment              = {{ peer.comment | default("Remote: " + peer.name) | tojson }}
}

{% endfor %}
# WireGuard Interface IP Address
resource "routeros_ip_address" "wg0" {
  address   = "{{ wireguard_address | default('10.100.0.1/30') }}"
  interface = routeros_interface_wireguard.wg0.name
  comment   = "WireGuard tunnel IP - managed by topology"
}

# Add WireGuard to LAN interface list (firewall trust)
resource "routeros_interface_list_member" "wg0_lan" {
  interface = routeros_interface_wireguard.wg0.name
  list      = "LAN"
  comment   = "Trust WireGuard tunnel - managed by topology"
}
{% for policy in routing_policies %}
{% if policy.enabled and not policy.staged %}

# ==============================================================================
# Policy-based routing: {{ policy.instance_id }}
# {{ policy.policy_name }} ({{ policy.source_subnet }} -> {{ policy.tunnel_interface }})
# ==============================================================================
{% if policy.routing_table and policy.routing_table.name %}
resource "routeros_routing_table" "{{ policy.name }}" {
  name = "{{ policy.routing_table.name }}"
  fib  = {{ 'true' if policy.routing_table.get('fib', True) else 'false' }}
  comment = "{{ policy.policy_name }} routing table - managed by topology"
}
{% endif %}
{% for rule in policy.mangle_rules %}

resource "routeros_ip_firewall_mangle" "{{ policy.name }}_mangle_{{ loop.index }}" {
  chain  = "{{ rule.chain }}"
  action = "{{ rule.action }}"
{% if rule.get('src_address') %}
  src_address = "{{ rule.get('src_address') }}"
{% endif %}
{% if rule.get('dst_address') %}
  dst_address = "{{ rule.get('dst_address') }}"
{% endif %}
{% if rule.get('connection_mark') %}
  connection_mark = "{{ rule.get('connection_mark') }}"
{% endif %}
{% if rule.get('new_connection_mark') %}
  new_connection_mark = "{{ rule.get('new_connection_mark') }}"
{% endif %}
{% if rule.get('new_routing_mark') %}
  new_routing_mark = "{{ rule.get('new_routing_mark') }}"
{% endif %}
  passthrough = {{ 'true' if rule.get('passthrough', True) else 'false' }}
  comment     = "{{ policy.policy_name }} mangle - managed by topology"
{% if loop.index > 1 %}
  depends_on = [routeros_ip_firewall_mangle.{{ policy.name }}_mangle_{{ loop.index - 1 }}]
{% elif policy.routing_table and policy.routing_table.name %}
  depends_on = [routeros_routing_table.{{ policy.name }}]
{% endif %}
}
{% endfor %}
{% for route in policy.routes %}

resource "routeros_ip_route" "{{ policy.name }}_route_{{ loop.index }}" {
  dst_address   = "{{ route.dst_address }}"
  gateway       = "{{ route.gateway }}"
{% if route.get('routing_table') %}
  routing_table = "{{ route.get('routing_table') }}"
{% endif %}
  comment       = "{{ policy.policy_name }} route - managed by topology"
{% if policy.routing_table and policy.routing_table.name %}
  depends_on = [routeros_routing_table.{{ policy.name }}]
{% endif %}
}
{% endfor %}
{% if has_security_matrix %}

# Tunnel egress: allow new connections from {{ policy.source_subnet }} out via {{ policy.tunnel_interface }}.
# The zone firewall (ADR 0110) ends the forward chain with a final drop-all,
# so without this rule marked traffic is routed into the tunnel but dropped.
# place_before keeps this rule ahead of the final drop-all on the router.
resource "routeros_ip_firewall_filter" "{{ policy.name }}_tunnel_egress" {
  chain         = "forward"
  action        = "accept"
  src_address   = "{{ policy.source_subnet }}"
  out_interface = "{{ policy.tunnel_interface }}"
  comment       = "{{ policy.policy_name }} tunnel egress - managed by topology"
  place_before  = routeros_ip_firewall_filter.zone_drop_all_forward.id

  depends_on = [routeros_interface_wireguard.wg0]
}
{% endif %}
{% endif %}
{% endfor %}
{% else %}
# WireGuard capability not enabled - no resources generated
{% endif %}

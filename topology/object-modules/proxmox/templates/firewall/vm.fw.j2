{# ADR 0110: Proxmox VM/LXC Firewall Template (STUB) #}
{#
This template will generate /etc/pve/firewall/<vmid>.fw for individual VMs/containers.

Status: STUB - Not yet implemented.

When implemented, this template will:
1. Set per-VM firewall options
2. Apply zone-specific rules based on VM's trust_zone_ref
3. Allow configured services (SSH, HTTP, etc.)

Variables expected:
- vmid: VM/container ID
- hostname: VM/container hostname
- trust_zone_ref: Reference to trust zone
- allowed_services: List of services to allow
- security_matrix: Global security matrix data
#}

[OPTIONS]
enable: 1
policy_in: DROP
policy_out: ACCEPT
log_level_in: warning
log_level_out: warning
macfilter: 0

[RULES]
{# Always allow established connections #}
IN ACCEPT -m conntrack --ctstate ESTABLISHED,RELATED

{% if allowed_services | default([]) %}
{# Service-specific rules #}
{% for service in allowed_services %}
{% if service.protocol | default('tcp') == 'tcp' %}
IN ACCEPT -p tcp -dport {{ service.port }} # {{ service.name | default('service') }}
{% elif service.protocol == 'udp' %}
IN ACCEPT -p udp -dport {{ service.port }} # {{ service.name | default('service') }}
{% endif %}
{% endfor %}
{% endif %}

{# Default: Allow ICMP ping #}
IN ACCEPT -p icmp

{# Generated for {{ hostname | default('unknown') }} (VMID: {{ vmid | default('?') }}) #}
{# Trust zone: {{ trust_zone_ref | default('none') }} #}
{# Generated by topology compiler - ADR 0110 #}

{# ADR 0110: Proxmox Cluster Firewall Template (STUB) #}
{#
This template will generate /etc/pve/firewall/cluster.fw from security_matrix.

Status: STUB - Not yet implemented.

When implemented, this template will:
1. Define ALIASES for each trust zone CIDR
2. Create IPSET entries for zone address lists
3. Generate security GROUPs for reusable rule sets
4. Create RULES based on R1-R6 matrix calculation

Variables expected:
- security_matrix: { zones: {...}, matrix: {...}, policy_overrides: [...] }
- has_security_matrix: boolean
#}

{# === OPTIONS === #}
[OPTIONS]
enable: 1
policy_in: DROP
policy_out: ACCEPT
log_level_in: warning
log_level_out: warning

{% if has_security_matrix | default(false) %}
{# === ALIASES (Zone CIDRs) === #}
[ALIASES]
{% for zone_name, zone_data in security_matrix.zones.items() %}
{% for cidr in zone_data.cidrs %}
zone_{{ zone_name | replace('inst.trust_zone.', '') }} = {{ cidr }}
{% endfor %}
{% endfor %}

{# === IPSETS (Zone Address Lists) === #}
{% for zone_name, zone_data in security_matrix.zones.items() %}
{% set zone_short = zone_name | replace('inst.trust_zone.', '') %}
[IPSET zone-{{ zone_short }}]
{% for cidr in zone_data.cidrs %}
{{ cidr }}
{% endfor %}

{% endfor %}

{# === SECURITY GROUPS === #}
{# TODO: Generate groups from policy_overrides #}

{# === RULES === #}
[RULES]
{# Established/related connections #}
IN ACCEPT -m conntrack --ctstate ESTABLISHED,RELATED

{# TODO: Generate rules from matrix #}
{# Example format:
IN ACCEPT -source +zone-user -dest +zone-servers -p tcp -dport 443
IN DROP -source +zone-guest -dest +zone-user -log warning
#}

{% else %}
{# No security matrix configured - use permissive defaults #}
[RULES]
IN ACCEPT -m conntrack --ctstate ESTABLISHED,RELATED
{% endif %}

